#######################################################################
# Joseph & Mike's Barbershop — environment configuration
# Copy this file to `.env` and fill in real values for production.
# The app runs fully offline with the dev defaults below (SQLite +
# console-logged notifications + mock checkout). Add provider keys to
# turn on real email / SMS / payments.
#######################################################################

# ---- Database ----------------------------------------------------
# Local dev (zero setup): SQLite file.
DATABASE_URL="file:./dev.db"
# Production (Supabase / any Postgres) — switch provider in
# prisma/schema.prisma to "postgresql" and use a pooled URL, e.g.:
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres?schema=public"

# ---- App ---------------------------------------------------------
# Public base URL (used for booking-management links & emails).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Default shop timezone (IANA name). Admins can change it in Settings.
SHOP_TIMEZONE="America/Toronto"

# ---- Auth --------------------------------------------------------
# REQUIRED in production. Generate one: `openssl rand -base64 48`
AUTH_SECRET="dev-only-insecure-secret-change-me-in-production-0123456789"
# Optional production hard allowlist for admin logins.
# Leave blank to trust active database users. Set comma-separated emails for an
# extra production gate, e.g. "owner@example.com,manager@example.com".
ADMIN_ALLOWED_EMAILS=""
# Local testing only. Enables a clearly marked dev admin bypass on localhost.
ALLOW_DEV_ADMIN_BYPASS="false"
# Setup mode: open /admin/signup so an owner can create the first admin
# account(s). Keep "false" in normal production so visitors can't self-register.
# Honors ADMIN_ALLOWED_EMAILS when set. First account created becomes OWNER.
ALLOW_ADMIN_SIGNUP="false"
# First owner account created by `npm run db:seed`.
SEED_ADMIN_EMAIL="owner@josephandmikes.com"
SEED_ADMIN_PASSWORD="ChangeMe!2024"

# ---- Email (Resend) — optional ----------------------------------
# Without a key, emails are logged to the NotificationLog table + console.
RESEND_API_KEY=""
EMAIL_FROM="Joseph & Mike's Barbershop <bookings@josephandmikes.com>"
# Where admin alert emails are delivered.
ADMIN_NOTIFICATION_EMAIL="owner@josephandmikes.com"

# ---- SMS (Twilio) — optional ------------------------------------
# Without these, SMS are logged to the NotificationLog table + console.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ---- Payments (Stripe) — optional -------------------------------
# Without a key, checkout runs in MOCK mode (orders/deposits are created
# and auto-marked paid so you can test the full flow offline).
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ---- Media uploads (Supabase Storage) — optional -----------------
# Admin image uploads use Supabase Storage when configured. Without these,
# admins can still paste image URLs into media fields.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="barbershop-media"
